# Adres produkcyjny strony (canonical, og:image, robots.txt, sitemap.xml)
VITE_SITE_URL=https://twoja-domena.pl

# Preset klienta — domyślnie szablon; nowy klient: skopiuj default.ts i ustaw tutaj id
VITE_CITY_PRESET=default

# Opcjonalnie: opinie na żywo z Google Places API
# GOOGLE_PLACES_API_KEY=
# googlePlaceId w presetcie (src/lib/presets/*.ts)

# Formularz kontaktowy — Web3Forms
VITE_WEB3FORMS_ACCESS_KEY=
